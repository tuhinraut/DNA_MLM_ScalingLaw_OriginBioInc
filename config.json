{
  "experiment": {
    "name": "DNA MLM Scaling Laws",
    "phases": ["iso_token", "iso_param", "iso_flop"],
    "note": "Per-run config lives in <experiment_dir>/configs/*.json; this file is informational only."
  },
  "data": {
    "source": "NCBI Genomes FTP (protein-coding CDS)",
    "downloader": "data_downloaders/download_ncbi_ftp.py",
    "expected_species": 33,
    "expected_tokens": 3950000000
  },
  "defaults": {
    "max_seq_len": 2048,
    "min_seq_len": 64,
    "batch_size": 32,
    "gradient_accumulation_steps": 1,
    "grad_clip": 1.0,
    "learning_rate": 1e-4,
    "mask_prob": 0.15,
    "warmup_frac": 0.05,
    "num_epochs": 1,
    "eval_every": 500,
    "seed": 42
  }
}
